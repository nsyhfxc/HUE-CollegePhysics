% Theorem-like and proof-like environments
\numberwithin{equation}{section}
\newenvironment{Proof}{\begin{proof}[\indent\bfseries 证明]}{\end{proof}}
\newenvironment{Solution}{\begin{proof}[\indent\bfseries 解]}{\end{proof}}
\theoremstyle{definition}
\newtheorem{definition}{\indent 定义}[section]
\newtheorem{theorem}{\indent 定理}[section]
\newtheorem{lemma}[theorem]{\indent 引理}
\newtheorem{corollary}[theorem]{\indent 推论}
\newtheorem{proposition}[theorem]{\indent 命题}
\newtheorem{example}{\indent 例}[section]
\newenvironment{Definition}[1][]{\begin{definition}[#1]\label{定义:#1}}{\end{definition}}
\newenvironment{Theorem}[1][]{\begin{theorem}[#1]\label{定理:#1}}{\end{theorem}}
\newenvironment{Lemma}[1][]{\begin{lemma}[#1]\label{引理:#1}}{\end{lemma}}
\newenvironment{Corollary}[1][]{\begin{corollary}[#1]\label{推论:#1}}{\end{corollary}}
\newenvironment{Proposition}[1][]{\begin{proposition}[#1]\label{命题:#1}}{\end{proposition}}
\newenvironment{Example}[1][]{\begin{example}[#1]\label{例:#1}}{\end{example}}

% Original boxed-note environments, centralized here instead of in chapters.
\newcounter{box}[section]
\renewcommand{\thebox}{\thesection.\arabic{box}}
\NewDocumentCommand{\boxadd}{}{\refstepcounter{box}\thebox}
\NewDocumentCommand{\BoxLabelIfNamed}{mm}{\ifstrempty{#1}{}{\ifstrempty{#2}{}{\label{#2:#1}}}}
\NewDocumentEnvironment{BoxBase}{O{}m}{%
    \begin{tcolorbox}[breakable,arc=0mm,title={\footnotesize #2(\boxadd\BoxLabelIfNamed{#1}{#2})\hfill #1}]%
}{%
    \end{tcolorbox}%
}
\NewDocumentEnvironment{BoxGeneral}{O{}O{}}{\begin{BoxBase}[#1]{#2}\small}{\end{BoxBase}}
\NewDocumentEnvironment{BoxPrinciple}{O{}}{\begin{BoxBase}[#1]{定律}\centering\small}{\end{BoxBase}}
\NewDocumentEnvironment{BoxEquation}{O{}}{\begin{BoxBase}[#1]{公式}\begin{equation*}}{\end{equation*}\end{BoxBase}}
\NewDocumentEnvironment{BoxDefinition}{O{}}{\begin{BoxBase}[#1]{定义}\begin{equation*}}{\end{equation*}\end{BoxBase}}
\NewDocumentEnvironment{BoxEq}{o}{\normalsize\begin{equation*}}{\end{equation*}\small}
\NewDocumentEnvironment{Equation}{o}{\begin{equation}\IfValueT{#1}{\label{式:#1}}}{\end{equation}}
\NewDocumentEnvironment{EquationBox}{o}{%
    \IfValueTF{#1}{\begin{tcolorbox}[breakable,arc=0mm,title={\footnotesize\hfill #1}]}{\begin{tcolorbox}[breakable,arc=0mm]}%
    \begin{equation}\IfValueT{#1}{\label{式:#1}}%
}{%
    \end{equation}\end{tcolorbox}%
}

