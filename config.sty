% TikZ point helpers.
\NewDocumentCommand{\lPoint}{mmoo}{%
    \IfNoValueTF{#3}{\coordinate (#1) at (#2);}{%
        \IfNoValueTF{#4}{\coordinate[label=#3:$#1$] (#1) at (#2);}{\coordinate[label=#3:$#4$] (#1) at (#2);}%
    }%
}
\NewDocumentCommand{\lShift}{mmmoo}{%
    \IfNoValueTF{#4}{\coordinate (#1) at ([shift={+(#3)}] #2);}{%
        \IfNoValueTF{#5}{\coordinate[label=#4:$#1$] (#1) at ([shift={+(#3)}] #2);}{\coordinate[label=#4:$#5$] (#1) at ([shift={+(#3)}] #2);}%
    }%
}
\NewDocumentCommand{\lRatio}{mmmmoo}{%
    \IfNoValueTF{#5}{\coordinate (#1) at ($(#2)!#4!(#3)$);}{%
        \IfNoValueTF{#6}{\coordinate[label=#5:$#1$] (#1) at ($(#2)!#4!(#3)$);}{\coordinate[label=#5:$#6$] (#1) at ($(#2)!#4!(#3)$);}%
    }%
}
\NewDocumentCommand{\lRoate}{mmmmmoo}{%
    \IfNoValueTF{#6}{\coordinate (#1) at ($(#2)!#4!#5:(#3)$);}{%
        \IfNoValueTF{#7}{\coordinate[label=#6:$#1$] (#1) at ($(#2)!#4!#5:(#3)$);}{\coordinate[label=#6:$#7$] (#1) at ($(#2)!#4!#5:(#3)$);}%
    }%
}
\NewDocumentCommand{\lIntersect}{mmmmmoo}{%
    \lRatio{TempIntersect1}{#2}{#3}{20cm}
    \lRatio{TempIntersect2}{#3}{#2}{20cm}
    \lRatio{TempIntersect3}{#4}{#5}{20cm}
    \lRatio{TempIntersect4}{#5}{#4}{20cm}
    \path[name path=TempIntersectPathA] (TempIntersect1)--(TempIntersect2);
    \path[name path=TempIntersectPathB] (TempIntersect3)--(TempIntersect4);
    \coordinate[name intersections={of=TempIntersectPathA and TempIntersectPathB,by={#1}}];
    \IfNoValueF{#6}{\IfNoValueTF{#7}{\node[#6] at (#1) {$#1$};}{\node[#6] at (#1) {$#7$};}}%
}
\NewDocumentCommand{\lProject}{mmmmoo}{%
    \lRatio{TempProject1}{#3}{#4}{20cm}
    \lRatio{TempProject2}{#4}{#3}{20cm}
    \coordinate (#1) at ($(TempProject1)!(#2)!(TempProject2)$);
    \IfNoValueF{#5}{\IfNoValueTF{#6}{\node[#5] at (#1) {$#1$};}{\node[#5] at (#1) {$#6$};}}%
}
\NewDocumentCommand{\lEroject}{mmmmmoo}{%
    \lRoate{TempEroject1}{#2}{#3}{1cm}{90}
    \lIntersect{#1}{#2}{TempEroject1}{#4}{#5}
    \IfNoValueF{#6}{\IfNoValueTF{#7}{\node[#6] at (#1) {$#1$};}{\node[#6] at (#1) {$#7$};}}%
}
\NewDocumentCommand{\lAngle}{O{}mmmO{0.25}O{2.3}D(){}}
    {\draw pic["$#1$",draw=black,angle radius=#5cm,angle eccentricity=#6,#7]{angle=#2--#3--#4};}
\NewDocumentCommand{\lRightAngle}{O{}mmmO{0.1}O{2.3}D(){}}
    {\draw pic["$#1$",draw=black,angle radius=#5cm,angle eccentricity=#6,#7]{right angle=#2--#3--#4};}

