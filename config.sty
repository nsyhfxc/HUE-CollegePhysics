% Keep compilation working when generated Python/Octave figures are absent.
\let\OriginalIncludeGraphics\includegraphics
\RenewDocumentCommand{\includegraphics}{O{}m}{%
    \IfFileExists{#2}{%
        \ifstrempty{#1}{\OriginalIncludeGraphics{#2}}{\OriginalIncludeGraphics[#1]{#2}}%
    }{%
        \fbox{\parbox{0.72\linewidth}{\centering\small 缺少图像文件：\texttt{\detokenize{#2}}}}%
    }%
}

